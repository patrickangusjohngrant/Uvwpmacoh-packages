# Content-addressed blob store; regenerated by depackagator.py
blobs/

# Raw .deb downloads; regenerated by download*.sh
source.deb/

# Per-package unpacked .deb trees produced by depackagator.py as a working
# directory. Only the resulting extracts/<pkg>.json manifests are tracked.
extracts/*/

# Cached BBC RSS feed for the dynamic MOTD; regenerated by refresh-news.sh
news.xml
news.xml.new
