# Minimal sshd_config for Uvwpmacoh QEMU smoke-test.
# All defaults are fine on Debian 13 (OpenSSH 9.x); the only thing we
# really care about is that root can log in.

Port 22

HostKey /etc/ssh/ssh_host_rsa_key
HostKey /etc/ssh/ssh_host_ecdsa_key
HostKey /etc/ssh/ssh_host_ed25519_key

PermitRootLogin yes
PasswordAuthentication yes
PermitEmptyPasswords no

# StrictModes off because the FUSE filesystem hands sshd files owned by
# whatever uid the depackagator preserved, and we don't bother to chown
# every parent directory at boot.
StrictModes no

# PAM off — modern openssh-server requires the full PAM stack to be wired up
# (libpam-modules, /etc/pam.d/sshd, /etc/pam.d/common-*). With PAM off sshd
# does its own crypt(3) check against /etc/shadow, which is what we want for
# the smoke-test image. Re-enable when libpam is properly merged.
UsePAM no
KbdInteractiveAuthentication no

Subsystem sftp /usr/lib/openssh/sftp-server
